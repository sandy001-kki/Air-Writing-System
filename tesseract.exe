    $(function() {
        bizx.cmp.ifConsent({ purposes: 'all' , vendors: 'narrative'}, function() {
            var current_time = (new Date()).getTime();
            let imageUrl = "https://io.narrative.io/?companyId=2440&id=first_party%3A22fe03d3-6840-4dd5-ba96-7a7ae3327967&id=site_name%3Asourceforge.net&id=url%3A%2Fprojects%2Ftesseract-ocr-alt%2Ffiles%2F&id=pagetitle%3Atesseract-ocr+alternative+download+-++Browse+Files+at+SourceForge.net&id=vertical%3AOpen+Source+Software&id=product%3Atesseract-ocr+alternative+download&id=topics%3AImage+Converters%2COCR&id=programming_language%3AC%2B%2B";
            imageUrl = imageUrl.replace(encodeURIComponent("$PAGE_TITLE"), document.title);  

            imageUrl = URL.parse(imageUrl);
            let hem = bizx.uids.getHem();
            if (hem) {
                imageUrl.searchParams.append('id', 'hem:' + hem);
            }
            imageUrl.searchParams.append('rand', current_time);

            var image = new Image();
            image.src = imageUrl.toString();
            image.style.display = "none";
            image.style.height = 0;
            image.style.width = 0;
            document.body.appendChild(image);
        });
    });
</script>
        

        
            
